# Application Settings
APP_NAME="CX Game Backend"
APP_VERSION="1.0.0"
ENVIRONMENT="production"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE="/var/log/cxgame/backend.log"

# Server Settings
HOST="0.0.0.0"
PORT=8000
WORKERS=4

# Redis Settings (VPS Local)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="your-redis-password-here"
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# Supabase Settings
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Firebase Settings
FIREBASE_CREDENTIALS_BASE64="your-firebase-credentials-base64"

# Security
ADMIN_SECRET="your-admin-secret-here"
CRON_SECRET="your-cron-secret-here"
JWT_SECRET="your-jwt-secret-here"
JWT_ALGORITHM="HS256"
# Must match CXGAME_SESSION_SECRET in Vercel for intermission games.

# CORS Settings
ALLOWED_ORIGINS="https://cxgame.vercel.app,https://cx-game.vercel.app,https://cx-game-beta.vercel.app,https://api.example.com"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
