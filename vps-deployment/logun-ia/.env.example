# Aplicação
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis (VPS local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firebase (opcional)
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_here

# Ollama (Mistral)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT_MS=8000

# OpenRouter (opcional - fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=10000

# Gemini (opcional - fallback)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TIMEOUT_MS=10000

# Logun Router
LOGUN_CIRCUIT_BREAKER_THRESHOLD=3
LOGUN_CIRCUIT_BREAKER_TIMEOUT_SEC=300
LOGUN_MAX_QUEUE_SIZE=100
LOGUN_CACHE_TTL_SEC=86400

# Rate Limiting
RATE_LIMIT_LOGUN_PER_MIN=10
RATE_LIMIT_LOGUN_BURST=5

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ADMIN_SECRET=your_admin_secret_here

# CORS
CORS_ORIGINS=https://cxgame.vercel.app,https://cx-game.vercel.app,https://cx-game-beta.vercel.app,https://api.example.com
