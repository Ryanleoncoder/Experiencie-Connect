# CX GAME - Environment Variables Template
# 
# IMPORTANTE: Este é apenas um template de exemplo!
# O arquivo .env real está na raiz do projeto: .env
# 
# Para configurar o projeto:
# 1. Vá para a raiz: a raiz do projeto
# 2. O arquivo .env já existe com as credenciais
# 3. Atualize as credenciais se necessário
#

# Supabase Configuration
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua-chave-sb-publishable-aqui
SUPABASE_ANON_KEY=sua-chave-sb-publishable-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# Alias para compatibilidade
SUPABASE_KEY=sua-chave-sb-publishable-aqui

# Notas:
# 
# - SUPABASE_ANON_KEY: Chave pública (segura para frontend)
# - SUPABASE_SERVICE_ROLE_KEY: Chave privada (apenas APIs)
# - SUPABASE_JWT_SECRET: Segredo JWT (opcional)
#
# O arquivo .env real está em: .env
# Este arquivo é apenas documentação/template
