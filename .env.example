# Experience Connect - Environment Variables Template
# Copie este arquivo para .env e preencha com suas credenciais reais
# 
# cp .env.example .env
#

# SUPABASE CONFIGURATION

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua-chave-sb-publishable-aqui
SUPABASE_ANON_KEY=sua-chave-sb-publishable-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# Alias para compatibilidade com código legado
SUPABASE_KEY=sua-chave-sb-publishable-aqui

# FIREBASE CONFIGURATION
# Firebase client-side configuration for Firestore
# These are PUBLIC values - security is enforced through Firestore Security Rules
#
# Get credentials from: https://console.firebase.google.com/
# 1. Go to Project Settings > General
# 2. Scroll to "Your apps" section
# 3. Select your web app or create one
# 4. Copy the config values below
#
# SECURITY NOTE:
# - These values are PUBLIC and safe to commit to version control
# - Security is enforced through Firestore Security Rules, not by hiding these values
# - The rules control who can read/write data in Firestore
# - Never rely on hiding these keys for security

FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# UPSTASH REDIS CONFIGURATION (OPTIONAL)
# Optional performance cache for rate limiting and login attempts
# 
# PRIMARY: Supabase RPC functions (always available, ~50ms)
# OPTIONAL: Redis cache (when configured, ~10ms)
# 
# CONTROL:
# - REDIS_ENABLED=true  → Use Redis if configured (default)
# - REDIS_ENABLED=false → Disable Redis, use only Supabase
# 
# BENEFITS (when configured):
# - 5x faster response time (~10ms vs ~50ms)
# - Saves 950 MB bandwidth (63% reduction)
# - Free tier: 10,000 commands/day (sufficient for 500 users)
# 
# SYSTEM BEHAVIOR:
# - WITHOUT Redis: Uses Supabase RPC (works normally)
# - WITH Redis: Uses Redis first, falls back to Supabase if unavailable
# - Fail-open strategy: Reliability > aggressive caching
#
# SETUP GUIDE: See docs/REDIS_SETUP_QUICKSTART.md
#
# Get credentials from: https://console.upstash.com/
# 1. Create account (free)
# 2. Create new Redis database (select Regional, choose region near Vercel)
# 3. Copy REST API URL → UPSTASH_REDIS_REST_URL
# 4. Copy REST API Token → UPSTASH_REDIS_REST_TOKEN

REDIS_ENABLED=true
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# FRONTEND CONFIGURATION
# Estas variáveis são carregadas pelo env-loader.js

CXGAME_VPS_API_BASE=https://api.vps.com.br
CXGAME_SESSION_SECRET=use-o-mesmo-valor-do-JWT_SECRET-da-vps
IP_HASH_SECRET=gere-com-openssl-rand-hex-32

# TESTING & DEVELOPMENT
# Bypass event window restrictions for testing
# 
# BYPASS_EVENT_WINDOW=true  → Ignora restrições de horário (07h-19h)
# BYPASS_EVENT_WINDOW=false → Aplica restrições normalmente (default)
# 
# IMPORTANTE:
# - Use APENAS em ambientes de teste/desenvolvimento
# - NUNCA ative em produção
# - Permite testar funcionalidades fora do horário do evento
# - Ainda respeita maintenance mode e season state

BYPASS_EVENT_WINDOW=false

# LOGUN-IA CONFIGURATION
# Logun-IA is the LLM-based text validation system for open-ended questions
# 
# OVERVIEW:
# - Validates text-based challenge responses using AI analysis
# - 2-tier fallback architecture: Mistral local (5s) → Rule Engine (2s)
# - Low volume: Only 1-2 text questions per level (1,500 validations/week for 500 users)
# - Highly viable: Uses only 0.0125% of Vercel bandwidth and 5.5% of serverless time
#
# ATTEMPT SYSTEM:
# - Text questions follow the SAME 3-attempt system as multiple choice questions
# - NO daily limit - attempts are controlled by Supabase via record_challenge_attempt
# - If user fails 3 times, challenge is marked as failed (same as normal challenges)
# - Rate limiting is ONLY for anti-spam (5 req/min)
#
# SETUP:
# 1. Deploy Logun-IA service to VPS (see vps-deployment/logun-ia/)
# 2. Configure LOGUN_IA_URL to point to your VPS endpoint
# 3. Generate API token for Bearer authentication
# 4. Set LOGUN_API_TOKEN (must be the SAME in Vercel and VPS)
# 5. Configure in Vercel Environment Variables
# 6. Configure in VPS: /home/ubuntu/app/logun-ia/.env (same values)
#
# SECURITY:
# - LOGUN_API_TOKEN must be the SAME in Vercel and VPS for Bearer Token validation
# - Never commit the actual token to Git
# - Use HTTPS only (token sent in Authorization header)
#
# CONFIGURATION:
# - LOGUN_IA_URL: Logun-IA service endpoint (VPS)
#   Example: https://your-vps-domain.com/logun/validate
#   Default: https://your-vps-domain.com/logun/validate
#
# - LOGUN_API_TOKEN: Bearer token for API authentication
#   Generate with: openssl rand -base64 32
#   CRITICAL: Must match VPS configuration exactly
#
# - LOGUN_TIMEOUT_MS: Total timeout budget for Logun-IA requests
#   Default: 8000 (8 seconds)
#   Breakdown: 5s for Mistral, 2s for Rule Engine fallback, 1s overhead
#   Range: 5000-10000 (Vercel has 10s serverless limit)
#
# - LOGUN_MAX_TEXT_LENGTH: Max text length in characters
#   Default: 2000
#   Purpose: Prevent abuse and control LLM token costs
#   Enforced before sending to Logun-IA

LOGUN_IA_URL=https://your-vps-domain.com/logun/validate
LOGUN_API_TOKEN=your-bearer-token-here
LOGUN_TIMEOUT_MS=8000
LOGUN_MAX_TEXT_LENGTH=2000

# BACKEND CONFIGURATION (Python)
# Porta do servidor backend (opcional)
# PORT=5000

# ONDE ENCONTRAR AS CREDENCIAIS
#
# 1. Acesse: https://supabase.com/dashboard
# 2. Selecione seu projeto
# 3. Vá em Settings > API
# 4. Copie:
#    - Project URL → SUPABASE_URL
#    - anon/public key → SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY
# 5. Para JWT_SECRET: Settings > API > JWT Settings > JWT Secret
#
# NOTAS DE SEGURANÇA
#
# - SUPABASE_ANON_KEY: Chave pública (segura para frontend, protegida por RLS)
# - SUPABASE_SERVICE_ROLE_KEY: Chave privada (NUNCA exponha no frontend!)
# - SUPABASE_JWT_SECRET: Segredo JWT (opcional, para validação de tokens)
#
# - O arquivo .env está no .gitignore (não será commitado)
# - NUNCA commite credenciais no código
# - Em produção, use variáveis de ambiente da Vercel


