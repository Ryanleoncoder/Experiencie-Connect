rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // ANSWER KEYS - BLOCK ALL CLIENT ACCESS
    // ============================================
    // Security critical: Answer keys must NEVER be accessible from client
    // Only Firebase Admin SDK (backend) can read these
    match /answer_keys/{document=**} {
      allow read, write: if false;  // Block all client access
    }
    
    // ============================================
    // SEASONS - PUBLIC READ ONLY
    // ============================================
    // Seasons are public data that clients need to read
    match /seasons/{seasonId} {
      allow read: if true;   // Anyone can read seasons
      allow write: if false; // Only admin can write (via Admin SDK)
    }
    
    // ============================================
    // LEVELS - PUBLIC READ ONLY
    // ============================================
    // Levels within seasons are public data
    match /seasons/{seasonId}/levels/{levelId} {
      allow read: if true;   // Anyone can read levels
      allow write: if false; // Only admin can write (via Admin SDK)
    }
    
    // ============================================
    // CHALLENGES - PUBLIC READ ONLY
    // ============================================
    // Challenges are public (but without answer keys)
    match /seasons/{seasonId}/levels/{levelId}/challenges/{challengeId} {
      allow read: if true;   // Anyone can read challenges
      allow write: if false; // Only admin can write (via Admin SDK)
    }
    
    // ============================================
    // ACHIEVEMENTS - PUBLIC READ ONLY
    // ============================================
    match /seasons/{seasonId}/achievements/{achievementId} {
      allow read: if true;   // Anyone can read achievements
      allow write: if false; // Only admin can write (via Admin SDK)
    }

    // Top-level achievements (lidos pela página de Conquistas — nome/desc/raridade/song/artist).
    // Conteúdo público; os answer_keys continuam bloqueados acima.
    match /achievements/{achievementId} {
      allow read: if true;
      allow write: if false; // Só Admin SDK escreve
    }

    // ============================================
    // DEFAULT DENY ALL
    // ============================================
    // Any other collection not explicitly allowed is blocked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
