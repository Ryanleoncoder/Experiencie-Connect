rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // CONTEUDO MIGRADO PARA O SUPABASE — LEITURA DO CLIENTE BLOQUEADA
    // ============================================
    // O conteudo do jogo (temporadas, niveis, desafios, conquistas) e servido
    // pelo Supabase (anon + RLS). O Firestore nao e mais lido pelo navegador.
    // Bloquear a leitura aqui fecha o vazamento do `resposta_correta` inline
    // que existia nos docs publicos de levels/challenges.
    // O Admin SDK (backend) ignora estas regras e segue funcionando p/ migracao.

    // ANSWER KEYS - nunca acessiveis pelo cliente (ja era bloqueado).
    match /answer_keys/{document=**} {
      allow read, write: if false;
    }

    // SEASONS / LEVELS / CHALLENGES / ACHIEVEMENTS - leitura do cliente negada.
    match /seasons/{seasonId} {
      allow read, write: if false;
    }
    match /seasons/{seasonId}/levels/{levelId} {
      allow read, write: if false;
    }
    match /seasons/{seasonId}/levels/{levelId}/challenges/{challengeId} {
      allow read, write: if false;
    }
    match /seasons/{seasonId}/achievements/{achievementId} {
      allow read, write: if false;
    }
    match /achievements/{achievementId} {
      allow read, write: if false;
    }

    // ============================================
    // DEFAULT DENY ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
