# BFF API Configuration

# Application
APP_NAME=CX-GAME BFF API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7
ADMIN_SECRET=your-admin-secret-change-this
CRON_SECRET=your-cron-secret-change-this
IP_HASH_SECRET=generate-with-openssl-rand-hex-32

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Connection Pool
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_BASE64=your-base64-encoded-service-account-json

# Firebase Collections
FIREBASE_CHALLENGES_COLLECTION=challenges
FIREBASE_ACHIEVEMENTS_COLLECTION=achievements

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
REDIS_TTL_SECONDS=300

# Event Window Configuration
EVENT_WINDOW_START_HOUR=7
EVENT_WINDOW_END_HOUR=19
EVENT_WINDOW_TIMEZONE=America/Sao_Paulo

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ENABLED=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Storage Configuration
SUPABASE_STORAGE_BUCKET=rankings
RANKING_FILE_PREFIX=ranking

# Game Configuration
MAX_ATTEMPTS_PER_CHALLENGE=3
XP_PER_LEVEL=500
XP_MULTIPLIERS=1.0,0.6,0.3

# Cron Jobs Configuration
RANKING_GENERATION_HOUR=19
RANKING_GENERATION_MINUTE=5
CLEANUP_RETENTION_DAYS=90
WARMUP_HOUR=6
WARMUP_MINUTE=55

# Monitoring (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
