{
  "name": "experience-connect-api-tests",
  "version": "2.0.0",
  "description": "Unit tests for Experience Connect API endpoints",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:progress": "jest frontend/__tests__/progress-flow-regression.test.js frontend/__tests__/intermission-flow-service.test.js api/__tests__/validate-challenge-access-cleanup.test.js frontend/__tests__/home-progress-sync-regression.test.js --runInBand",
    "verify:progress": "npm run test:progress && node scripts/repair-supabase-user-progress.js --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@upstash/redis": "^1.28.0",
    "dotenv": "^16.0.3",
    "firebase": "^12.12.0",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "fast-check": "^4.6.0",
    "firebase-admin": "^13.8.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-environment-node": "^29.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.vercel/",
      "<rootDir>/invite/"
    ],
    "collectCoverageFrom": [
      "api/**/*.js",
      "!api/**/*.test.js"
    ]
  }
}
